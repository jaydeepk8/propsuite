# ── Environment template ───────────────────────────────
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# SQLite (development):
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (production):
# DATABASE_URL=postgres://user:password@localhost:5432/propsuite

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=PropSuite <no-reply@propsuite.local>

# Absolute base URL (used to build QR-code links, emails, etc.)
SITE_URL=http://127.0.0.1:8000

# ── Production only (ignored while DEBUG=True) ─────────
# DEBUG=False
# ALLOWED_HOSTS=propsuite.example.com
# CSRF_TRUSTED_ORIGINS=https://propsuite.example.com
# DATABASE_URL=postgres://user:password@localhost:5432/propsuite
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
